<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" style="-fx-padding: 20; -fx-spacing: 15;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.dialogs.RecordEggCollectionDialogController">

    <children>
        <VBox layoutX="10.0" layoutY="10.0" prefHeight="380.0" prefWidth="480.0" spacing="15.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
            
            <!-- Error Label -->
            <Label fx:id="errorLabel" style="-fx-text-fill: #dc3545; -fx-padding: 8; -fx-background-color: #f8d7da; -fx-border-color: #f5c6cb; -fx-border-radius: 4; -fx-background-radius: 4;" text="Error message" visible="false" wrapText="true" />

            <!-- House Selection -->
            <VBox spacing="8.0">
                <Label style="-fx-font-size: 14; -fx-font-weight: bold;" text="Sélectionner la Maison" />
                <ComboBox fx:id="houseSelector" prefHeight="35.0" prefWidth="460.0" promptText="Choisir une maison pondeuse" />
            </VBox>

            <!-- Eggs Collected -->
            <VBox spacing="8.0">
                <Label style="-fx-font-size: 14; -fx-font-weight: bold;" text="Œufs Collectés" />
                <TextField fx:id="eggsCollectedField" prefHeight="35.0" prefWidth="460.0" promptText="Nombre d'œufs collectés" style="-fx-font-size: 12;" />
            </VBox>

            <!-- Cracked Eggs -->
            <VBox spacing="8.0">
                <Label style="-fx-font-size: 14; -fx-font-weight: bold;" text="Œufs Cracked" />
                <TextField fx:id="crackedEggsField" prefHeight="35.0" prefWidth="460.0" promptText="Nombre d'œufs cracked/cassés" style="-fx-font-size: 12;" />
            </VBox>

            <!-- Date Picker -->
            <VBox spacing="8.0">
                <Label style="-fx-font-size: 14; -fx-font-weight: bold;" text="Date de Collecte" />
                <DatePicker fx:id="collectionDatePicker" prefHeight="35.0" prefWidth="460.0" />
            </VBox>

            <!-- Notes -->
            <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 14; -fx-font-weight: bold;" text="Notes (Optionnel)" />
                <TextArea fx:id="notesArea" prefHeight="80.0" prefWidth="460.0" promptText="Ajouter des notes..." style="-fx-font-size: 12; -fx-control-inner-background: #f9f9f9; -fx-padding: 8;" wrapText="true" />
            </VBox>

            <!-- Buttons -->
            <HBox prefHeight="40.0" prefWidth="460.0" spacing="10.0">
                <Button fx:id="saveButton" prefHeight="35.0" prefWidth="225.0" style="-fx-font-size: 12; -fx-padding: 8;" text="Enregistrer" />
                <Button fx:id="cancelButton" prefHeight="35.0" prefWidth="225.0" style="-fx-font-size: 12; -fx-padding: 8;" text="Annuler" />
            </HBox>

        </VBox>
    </children>
</AnchorPane>
