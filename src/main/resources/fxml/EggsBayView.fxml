<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="950.0" styleClass="main-content" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.EggsBayController">

    <children>
        <VBox styleClass="header" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="15.0" left="30.0" right="30.0" top="15.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Label styleClass="header-title" text="Espace Œufs" textAlignment="LEFT" />
                                <Label styleClass="header-subtitle" text="Gérez la collecte, le stockage et la qualité des œufs" textAlignment="LEFT" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </padding>
                            <children>
                                <Button fx:id="recordCollectionButton" onAction="#handleRecordCollection" text="📝 Enregistrer Collecte">
                                    <styleClass>
                                        <String fx:value="btn" />
                                        <String fx:value="btn-save" />
                                    </styleClass>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="60.0">
            <children>
                <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="main-content" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="40.0" styleClass="main-content">
                            <children>
                                <!-- House Cards Container -->
                                <HBox fx:id="houseCardsContainer" spacing="40.0">
                                    <children>
                                        <!-- House 2 Card (Default: Not configured) -->
                                        <VBox fx:id="house2Card" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="h2NameLabel" styleClass="cards-title" text="Bâtiment 2 - Non configuré" />
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="house-info" text="🥚 Œufs du jour :" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="h2EggsCollectedLabel" text="00">
                                                            <styleClass>
                                                                <String fx:value="cards-title" />
                                                                <String fx:value="house-info-stats-production" />
                                                            </styleClass>
                                                        </Label>
                                                    </children>
                                                    <padding>
                                                        <Insets left="10.0" />
                                                    </padding>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="house-info" text="⚠ Cracked :" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="h2CrackedEggsLabel" text="00">
                                                            <styleClass>
                                                                <String fx:value="house-info-stats-deaths" />
                                                                <String fx:value="cards-title" />
                                                            </styleClass>
                                                        </Label>
                                                    </children>
                                                    <padding>
                                                        <Insets left="10.0" />
                                                    </padding>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="house-info" text="📅 Date :" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="h2DateLabel" styleClass="date-label" text="--/--/----" />
                                                    </children>
                                                    <padding>
                                                        <Insets left="10.0" />
                                                    </padding>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- House 3 Card (Default: Not configured) -->
                                        <VBox fx:id="house3Card" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="h3NameLabel" styleClass="cards-title" text="Bâtiment 3 - Non configuré" />
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="house-info" text="🥚 Œufs du jour :" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="h3EggsCollectedLabel" text="00">
                                                            <styleClass>
                                                                <String fx:value="cards-title" />
                                                                <String fx:value="house-info-stats-production" />
                                                            </styleClass>
                                                        </Label>
                                                    </children>
                                                    <padding>
                                                        <Insets left="10.0" />
                                                    </padding>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="house-info" text="⚠ Cracked :" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="h3CrackedEggsLabel" text="00">
                                                            <styleClass>
                                                                <String fx:value="house-info-stats-deaths" />
                                                                <String fx:value="cards-title" />
                                                            </styleClass>
                                                        </Label>
                                                    </children>
                                                    <padding>
                                                        <Insets left="10.0" />
                                                    </padding>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="house-info" text="📅 Date :" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="h3DateLabel" styleClass="date-label" text="--/--/----" />
                                                    </children>
                                                    <padding>
                                                        <Insets left="10.0" />
                                                    </padding>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- No Egg Laying Houses Message (Hidden by default) -->
                                <VBox fx:id="noEggHousesMessage" managed="false" visible="false">
                                    <styleClass>
                                        <String fx:value="metric-card" />
                                        <String fx:value="no-data-card" />
                                    </styleClass>
                                    <children>
                                        <HBox alignment="CENTER">
                                            <children>
                                                <VBox alignment="CENTER" spacing="15.0">
                                                    <children>
                                                        <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                                                            <image>
                                                                <Image url="@../images/icons/no-eggs.png" />
                                                            </image>
                                                        </ImageView>
                                                        <Label styleClass="no-data-title" text="🚫 Aucune maison pondeuse configurée" />
                                                        <Label styleClass="no-data-subtitle" text="Configurez des bâtiments de type 'Pondeuses' ou 'Femelles à Viande' pour commencer la collecte d'œufs" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <!-- Storage Card -->
                                <HBox>
                                    <children>
                                        <VBox fx:id="storageCard" styleClass="storage-card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                    <children>
                                                        <Label styleClass="storage-title" text="Stock d'œufs" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="storageStatusLabel" styleClass="health-good" text="Status">
                                                            <padding>
                                                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                                                            </padding>
                                                        </Label>
                                                        <Button fx:id="sellEggsButton" onAction="#handleSellEggs" text="💰 Vendre">
                                                            <styleClass>
                                                                <String fx:value="btn" />
                                                                <String fx:value="btn-sell" />
                                                            </styleClass>
                                                        </Button>
                                                    </children>
                                                </HBox>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label fx:id="totalEggsLabel" styleClass="storage-summary" text="000000" />
                                                        <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                                                            <image>
                                                                <Image url="@../images/icons/egg.png" />
                                                            </image>
                                                        </ImageView>
                                                    </children>
                                                    <padding>
                                                        <Insets left="40.0" />
                                                    </padding>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Statistics Cards - PRODUCTION & CRACKED -->
                                <HBox spacing="40.0">
                                    <!-- Production Statistics Card -->
                                    <VBox fx:id="productionStatsCard" spacing="15.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label styleClass="cards-title" text="Œufs Produits" />
                                            <HBox alignment="CENTER_LEFT" spacing="30.0">
                                                <children>
                                                    <VBox spacing="5.0">
                                                        <children>
                                                            <Label styleClass="house-info" text="📅 Aujourd'hui" />
                                                            <Label fx:id="productionTodayLabel" styleClass="cards-title" text="0" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="5.0">
                                                        <children>
                                                            <Label styleClass="house-info" text="📊 Cette Semaine" />
                                                            <Label fx:id="productionWeekLabel" styleClass="cards-title" text="0" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="5.0">
                                                        <children>
                                                            <Label styleClass="house-info" text="🗓 Ce Mois" />
                                                            <Label fx:id="productionMonthLabel" styleClass="cards-title" text="0" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                                <padding>
                                                    <Insets left="10.0" />
                                                </padding>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <!-- Cracked Statistics Card -->
                                    <VBox fx:id="crackedStatsCard" spacing="15.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label styleClass="cards-title" text="Œufs Cracked" />
                                            <HBox alignment="CENTER_LEFT" spacing="30.0">
                                                <children>
                                                    <VBox spacing="5.0">
                                                        <children>
                                                            <Label styleClass="house-info" text="📅 Aujourd'hui" />
                                                            <Label fx:id="crackedTodayLabel" styleClass="cards-title" text="0" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="5.0">
                                                        <children>
                                                            <Label styleClass="house-info" text="📊 Cette Semaine" />
                                                            <Label fx:id="crackedWeekLabel" styleClass="cards-title" text="0" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="5.0">
                                                        <children>
                                                            <Label styleClass="house-info" text="🗓 Ce Mois" />
                                                            <Label fx:id="crackedMonthLabel" styleClass="cards-title" text="0" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                                <padding>
                                                    <Insets left="10.0" />
                                                </padding>
                                            </HBox>
                                        </children>
                                    </VBox>
                                </HBox>
                            </children>
                            <padding>
                                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
