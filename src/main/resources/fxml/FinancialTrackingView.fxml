<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="950.0" styleClass="main-content" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.FinancialTrackingController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <!-- Title and Actions -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label styleClass="page-title" text="Suivi Financier" />
                        <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                            <Button fx:id="exportAllBtn" text="📥 Exporter Tout (PDF)">
                        <styleClass>
                           <String fx:value="btn" />
                           <String fx:value="btn-cancel" />
                        </styleClass></Button>
                        </HBox>
                    </children>
                </HBox>

                <!-- Filter Bar -->
                <HBox alignment="CENTER_LEFT" spacing="50.0" styleClass="metric-card">
                    <children>
                        <Label styleClass="card-title" text="Filtrer:" />
                        <ComboBox fx:id="typeFilterCombo" prefWidth="150.0" promptText="Type" stylesheets="@../css/dialogs.css" />
                        <ComboBox fx:id="entityFilterCombo" prefWidth="150.0" promptText="Tiers" stylesheets="@../css/dialogs.css" />
                    </children>
                </HBox>

                <!-- Summary Cards -->
                <HBox spacing="15.0">
                    <children>
                        <!-- Card 1: Total Income -->
                        <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #e8f5e9;" styleClass="metric-card" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 16px; -fx-text-fill: #388e3c;" styleClass="house-info" text="📈 Recettes" />
                            <Label fx:id="totalIncomeLabel" style="-fx-text-fill: #2e7d32;" styleClass="label-cards-stats" text="0.00 DH" />
                        </VBox>
                        <!-- Card 2: Total Expense -->
                        <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #ffebee;" styleClass="metric-card" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 16px; -fx-text-fill: #c62828;" styleClass="house-info" text="📉 Dépenses" />
                            <Label fx:id="totalExpenseLabel" style="-fx-text-fill: #b71c1c;" styleClass="label-cards-stats" text="0.00 DH" />
                        </VBox>
                        <!-- Card 3: Net Balance -->
                        <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #e3f2fd;" styleClass="metric-card" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 16px; -fx-text-fill: #1565c0;" styleClass="house-info" text="💵 Solde Net" />
                            <Label fx:id="netBalanceLabel" style="-fx-text-fill: #0d47a1;" styleClass="label-cards-stats" text="0.00 DH" />
                        </VBox>
                        <!-- Card 4: Outstanding -->
                        <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #fff3e0;" styleClass="metric-card" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-size: 16px; -fx-text-fill: #e65100;" styleClass="house-info" text="⏳ Impayés Clients" />
                            <Label fx:id="outstandingLabel" style="-fx-text-fill: #bf360c;" styleClass="label-cards-stats" text="0.00 DH" />
                        </VBox>
                    </children>
                </HBox>
            <VBox styleClass="metric-card" VBox.vgrow="ALWAYS">
               <children>
      
                      <!-- Transactions Table -->
                      <TableView fx:id="transactionTable" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                          <columns>
                              <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                              <TableColumn fx:id="colDate" prefWidth="100.0" text="Date" />
                              <TableColumn fx:id="colType" prefWidth="80.0" text="Type" />
                              <TableColumn fx:id="colCategory" prefWidth="120.0" text="Catégorie" />
                              <TableColumn fx:id="colEntity" prefWidth="140.0" text="Tiers" />
                              <TableColumn fx:id="colAmount" prefWidth="90.0" text="Montant" />
                              <TableColumn fx:id="colDescription" prefWidth="180.0" text="Description" />
                              <TableColumn fx:id="colActions" prefWidth="80.0" text="Actions" />
                          </columns>
                          <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                          </columnResizePolicy>
                      </TableView>
               </children>
            </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
