<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="550.0" prefHeight="650.0" spacing="15.0"
      style="-fx-background-color: #ffffff;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ma.farm.controller.dialogs.ConfigHousesDialogController">
    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
    </padding>

    <!-- Header -->
    <VBox spacing="5.0">
        <Label text="🏠 Configure Houses"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e2939;"/>
        <Label text="Set the number of houses and their capacities for each category."
               style="-fx-font-size: 13px; -fx-text-fill: #666666;" wrapText="true"/>
    </VBox>

    <Separator />

    <!-- Warning Message (shown if houses have chickens) -->
    <HBox fx:id="warningBox" spacing="10.0" alignment="CENTER_LEFT"
          style="-fx-background-color: #fff3cd; -fx-padding: 12; -fx-background-radius: 5;"
          visible="false" managed="false">
        <Label text="⚠" style="-fx-font-size: 18px; -fx-text-fill: #856404;"/>
        <Label fx:id="warningLabel"
               text="Cannot reconfigure: Some houses contain chickens. Empty all houses first."
               wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #856404;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <VBox spacing="15.0" style="-fx-background-color: transparent;">
            <padding>
                <Insets right="10.0" top="5.0" bottom="5.0"/>
            </padding>

            <!-- DayOld Section -->
            <VBox spacing="12.0"
                  style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="🐣 DayOld Houses"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
                    <Label text="(24 weeks lifecycle)" style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label text="Number of houses:" prefWidth="140.0" style="-fx-text-fill: #333333;"/>
                    <Spinner fx:id="dayOldSpinner" prefWidth="90.0"/>
                </HBox>
                <VBox fx:id="dayOldCapacityContainer" spacing="8.0">
                    <!-- Capacity fields will be added dynamically -->
                </VBox>
            </VBox>

            <!-- FemaleEggLayer Section -->
            <VBox spacing="12.0"
                  style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="🥚 Female Egg Layer Houses"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #E91E63;"/>
                    <Label text="(48 weeks lifecycle)" style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label text="Number of houses:" prefWidth="140.0" style="-fx-text-fill: #333333;"/>
                    <Spinner fx:id="eggLayerSpinner" prefWidth="90.0"/>
                </HBox>
                <VBox fx:id="eggLayerCapacityContainer" spacing="8.0">
                    <!-- Capacity fields will be added dynamically -->
                </VBox>
            </VBox>

            <!-- FemaleMeat Section -->
            <VBox spacing="12.0"
                  style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="🍗 Female Meat Houses"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #9C27B0;"/>
                    <Label text="(6 weeks lifecycle)" style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label text="Number of houses:" prefWidth="140.0" style="-fx-text-fill: #333333;"/>
                    <Spinner fx:id="femaleMeatSpinner" prefWidth="90.0"/>
                </HBox>
                <VBox fx:id="femaleMeatCapacityContainer" spacing="8.0">
                    <!-- Capacity fields will be added dynamically -->
                </VBox>
            </VBox>

            <!-- MaleMeat Section -->
            <VBox spacing="12.0"
                  style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="🐔 Male Meat Houses"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <Label text="(8 weeks lifecycle)" style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label text="Number of houses:" prefWidth="140.0" style="-fx-text-fill: #333333;"/>
                    <Spinner fx:id="maleMeatSpinner" prefWidth="90.0"/>
                </HBox>
                <VBox fx:id="maleMeatCapacityContainer" spacing="8.0">
                    <!-- Capacity fields will be added dynamically -->
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

    <Separator />

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="12.0">
        <padding>
            <Insets top="10.0"/>
        </padding>
        <Button fx:id="cancelButton" onAction="#handleCancel" text="Cancel"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"
                prefWidth="100"/>
        <Button fx:id="saveButton" onAction="#handleSave" text="Save Configuration"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"
                prefWidth="160"/>
    </HBox>
</VBox>
