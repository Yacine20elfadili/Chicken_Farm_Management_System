<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="550.0" spacing="15.0" styleClass="root" stylesheets="@../../css/dialogs.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.dialogs.AddEditTaskDialogController">

    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
    </padding>

    <!-- Header -->
    <VBox spacing="5.0">
        <Label fx:id="dialogTitle" styleClass="title" text="📝 Nouvelle Tâche" />
        <Label styleClass="subtitle" text="Remplissez les champs pour créer une tâche" />
    </VBox>

    <Separator />

    <!-- Form Content -->
    <ScrollPane fitToWidth="true" styleClass="transparent-scroll" VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="15.0" style="-fx-background-color: transparent;">
                <children>

                    <!-- Description -->
                    <VBox spacing="5.0">
                        <children>
                            <Label styleClass="section-title" text="Description *" />
                            <TextArea fx:id="descriptionField" prefRowCount="3" promptText="Décrivez la tâche à effectuer..." wrapText="true" />
                            <Label fx:id="descriptionErrorLabel" managed="false" styleClass="error-label" text="La description est requise" visible="false" />
                        </children>
                    </VBox>
                      <VBox spacing="5.0">
                          <children>
                              <Label styleClass="section-title" text="Catégorie *" />
                              <ComboBox fx:id="categoryComboBox" promptText="Sélectionner..." />
                              <Label fx:id="categoryErrorLabel" managed="false" styleClass="error-label" text="La catégorie est requise" visible="false" />
                          </children>
                      </VBox>
                      <VBox spacing="5.0">
                          <children>
                              <Label styleClass="section-title" text="Priorité *" />
                              <ComboBox fx:id="priorityComboBox" promptText="Sélectionner..." />
                          </children>
                      </VBox>
                      <VBox spacing="5.0">
                          <children>
                              <Label styleClass="section-title" text="Date Échéance *" />
                              <DatePicker fx:id="dueDatePicker" promptText="JJ/MM/AAAA" />
                              <Label fx:id="dueDateErrorLabel" managed="false" styleClass="error-label" text="La date est requise" visible="false" />
                          </children>
                      </VBox>
                      <VBox fx:id="houseSection" spacing="5.0">
                          <children>
                              <Label styleClass="section-title" text="Bâtiment" />
                              <ComboBox fx:id="houseComboBox" promptText="Sélectionner..." />
                          </children>
                      </VBox>

                    <!-- Assigned To -->
                    <VBox spacing="5.0">
                        <children>
                            <Label styleClass="section-title" text="Assigner à" />
                            <ComboBox fx:id="assignedToComboBox" promptText="Sélectionner un employé..." />
                        </children>
                    </VBox>

                    <!-- Cracked Eggs (only for Collection) -->
                    <VBox fx:id="crackedEggsSection" managed="false" spacing="5.0" visible="false">
                        <children>
                            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" text="Œufs cassés" />
                            <Spinner fx:id="crackedEggsSpinner" prefWidth="150.0" style="-fx-font-size: 13px;" />
                        </children>
                    </VBox>

                    <!-- Notes -->
                    <VBox spacing="5.0">
                        <children>
                            <Label styleClass="section-title" text="Notes" />
                            <TextArea fx:id="notesField" prefRowCount="2" promptText="Notes supplémentaires (optionnel)..." wrapText="true" />
                        </children>
                    </VBox>

                </children>
            </VBox>
        </content>
    </ScrollPane>

    <Separator />

    <!-- Footer Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <children>
            <Button fx:id="cancelButton" onAction="#handleCancel" text="Annuler">
            <styleClass>
               <String fx:value="btn" />
               <String fx:value="btn-cancel" />
            </styleClass></Button>
            <Button fx:id="saveButton" onAction="#handleSave" text="Enregistrer">
            <styleClass>
               <String fx:value="btn" />
               <String fx:value="btn-save" />
            </styleClass></Button>
        </children>
    </HBox>

</VBox>
