<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.farm.controller.dialogs.ManageEquipmentItemsDialogController"
      prefHeight="600.0" prefWidth="800.0" spacing="15.0" styleClass="dialog-container">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Dialog Title -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label styleClass="dialog-title" text="Gérer: " />
        <Label fx:id="categoryNameLabel" styleClass="dialog-title-highlight" text="Catégorie" />
    </HBox>

    <!-- Stats Row -->
    <HBox spacing="20.0" alignment="CENTER_LEFT" styleClass="stats-container">
        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-card">
            <Label styleClass="stat-label" text="Total" />
            <Label fx:id="itemCountLabel" styleClass="stat-value" text="0" />
        </VBox>

        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-card stat-good">
            <Label styleClass="stat-label" text="Bon État" />
            <Label fx:id="goodCountLabel" styleClass="stat-value" text="0" />
        </VBox>

        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-card stat-fair">
            <Label styleClass="stat-label" text="État Moyen" />
            <Label fx:id="fairCountLabel" styleClass="stat-value" text="0" />
        </VBox>

        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-card stat-broken">
            <Label styleClass="stat-label" text="Cassé" />
            <Label fx:id="brokenCountLabel" styleClass="stat-value" text="0" />
        </VBox>
    </HBox>

    <!-- Items List -->
    <VBox spacing="10.0" VBox.vgrow="ALWAYS">
        <Label styleClass="section-label" text="Équipements Individuels" />
        <ListView fx:id="itemsListView" prefHeight="300.0" styleClass="items-list-view" VBox.vgrow="ALWAYS" />
    </VBox>

    <!-- Action Buttons -->
    <HBox spacing="10.0">
        <Button fx:id="addItemButton" onAction="#handleAddItem" styleClass="btn-success" text="➕ Ajouter" HBox.hgrow="ALWAYS" />
        <Button fx:id="editItemButton" onAction="#handleEditItem" styleClass="btn-primary" text="✏️ Modifier" HBox.hgrow="ALWAYS" />
        <Button fx:id="deleteItemButton" onAction="#handleDeleteItem" styleClass="btn-danger" text="✖ Supprimer" HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Close Button -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
        <Button onAction="#handleClose" styleClass="btn-secondary" text="Fermer" />
    </HBox>
</VBox>