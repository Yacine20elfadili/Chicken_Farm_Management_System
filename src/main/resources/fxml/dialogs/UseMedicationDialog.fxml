<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="350.0" prefWidth="500.0" spacing="15.0" style="-fx-background-color: #f8f9fa;" styleClass="dialog-container" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.dialogs.UseMedicationDialogController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Dialog Title -->
    <Label style="-fx-font-size: 24; -fx-font-weight: bold;" styleClass="dialog-title" text="Utiliser Médicament" />

    <!-- Medication Info -->
    <VBox spacing="10.0" styleClass="info-box">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #495057;" styleClass="info-label" text="Médicament:" />
            <Label fx:id="medicationNameLabel" styleClass="info-value" text="Nom du médicament" />
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #495057;" styleClass="info-label" text="Stock:" />
            <Label fx:id="currentStockLabel" styleClass="info-value" text="0 unités" />
        </HBox>
    </VBox>

    <!-- Form Content -->
    <VBox spacing="15.0">
        <!-- Quantity -->
        <VBox spacing="5.0">
            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #495057;" styleClass="form-label" text="Quantité à Utiliser *" />
            <TextField fx:id="quantityField" promptText="Ex: 10" style="-fx-font-size: 13; -fx-padding: 10; -fx-background-color: transparent; -fx-border-color: black; -fx-border-radius: 5; -fx-background-radius: 5;" styleClass="form-input" />
            <Label fx:id="quantityErrorLabel" styleClass="error-label" text="" />
        </VBox>

        <!-- Worker Selection -->
        <VBox spacing="5.0">
            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #495057;" styleClass="form-label" text="Travailleur *" />
            <ComboBox fx:id="workerComboBox" prefWidth="300.0" promptText="Sélectionner le travailleur" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-radius: 5; -fx-background-radius: 5;" styleClass="form-input" />
            <Label fx:id="workerErrorLabel" styleClass="error-label" text="" />
        </VBox>
    </VBox>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
        <Button onAction="#handleCancel" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14; -fx-background-radius: 5; -fx-cursor: hand;" styleClass="btn-secondary" text="Annuler" />
        <Button onAction="#handleUse" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14; -fx-background-radius: 5; -fx-cursor: hand;" styleClass="btn-primary" text="Utiliser" />
    </HBox>
</VBox>
