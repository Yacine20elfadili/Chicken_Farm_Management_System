<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.farm.controller.dialogs.UseMedicationDialogController"
      prefHeight="350.0" prefWidth="500.0" spacing="15.0" styleClass="dialog-container">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Dialog Title -->
    <Label styleClass="dialog-title" text="Utiliser Médicament" />

    <!-- Medication Info -->
    <VBox spacing="10.0" styleClass="info-box">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label styleClass="info-label" text="Médicament:" />
            <Label fx:id="medicationNameLabel" styleClass="info-value" text="Nom du médicament" />
        </HBox>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label styleClass="info-label" text="Stock:" />
            <Label fx:id="currentStockLabel" styleClass="info-value" text="0 unités" />
        </HBox>
    </VBox>

    <!-- Form Content -->
    <VBox spacing="15.0">
        <!-- Quantity -->
        <VBox spacing="5.0">
            <Label styleClass="form-label" text="Quantité à Utiliser *" />
            <TextField fx:id="quantityField" promptText="Ex: 10" styleClass="form-input" />
            <Label fx:id="quantityErrorLabel" styleClass="error-label" text="" />
        </VBox>

        <!-- Worker Selection -->
        <VBox spacing="5.0">
            <Label styleClass="form-label" text="Travailleur *" />
            <ComboBox fx:id="workerComboBox" prefWidth="300.0" promptText="Sélectionner le travailleur" styleClass="form-input" />
            <Label fx:id="workerErrorLabel" styleClass="error-label" text="" />
        </VBox>
    </VBox>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="Annuler" />
        <Button onAction="#handleUse" styleClass="btn-primary" text="Utiliser" />
    </HBox>
</VBox>