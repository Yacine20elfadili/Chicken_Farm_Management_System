<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>

<AnchorPane prefHeight="700.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.dialogs.AddEditPersonnelDialogController" style="-fx-background-color: #f8f9fa;">

    <children>
        <!-- Header Section -->
        <VBox prefHeight="80.0" prefWidth="600.0" style="-fx-background-color: #007bff;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>
            <children>
                <Label fx:id="dialogTitle" text="Ajouter Personnel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
                <Label text="Remplissez tous les champs obligatoires (*)" style="-fx-font-size: 13px; -fx-text-fill: #e3f2fd;" />
            </children>
        </VBox>

        <!-- Warning Banner (Hidden by default) -->
        <HBox fx:id="noSupervisorWarningLabel" spacing="10.0" style="-fx-background-color: #fff3cd; -fx-border-color: #ffc107; -fx-border-width: 2px; -fx-padding: 15px; -fx-background-radius: 5px; -fx-border-radius: 5px;"
              AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="90.0" visible="false" managed="false">
            <children>
                <Label text="⚠️" style="-fx-font-size: 20px;" />
                <Label text="Aucun superviseur disponible. Veuillez ajouter un superviseur avant d'ajouter des ouvriers."
                       style="-fx-font-size: 13px; -fx-text-fill: #856404; -fx-font-weight: bold;" wrapText="true" />
            </children>
        </HBox>

        <!-- Form Content -->
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="70.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="90.0" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
                    </padding>
                    <children>

                        <!-- Personal Information Section -->
                        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label text="Informations Personnelles" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #343a40;" />

                                <!-- Full Name -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Nom Complet *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                        <TextField fx:id="fullNameField" promptText="Ex: Ahmed Hassan" style="-fx-font-size: 13px; -fx-padding: 10px;" />
                                        <Label fx:id="fullNameErrorLabel" text="Le nom complet est requis" style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" visible="false" managed="false"/>
                                    </children>
                                </VBox>

                                <!-- Age and Phone Row -->
                                <GridPane hgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                                    </columnConstraints>
                                    <children>
                                        <!-- Age -->
                                        <VBox spacing="5.0" GridPane.columnIndex="0">
                                            <children>
                                                <Label text="Âge *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                                <TextField fx:id="ageField" promptText="Ex: 30" style="-fx-font-size: 13px; -fx-padding: 10px;" />
                                                <Label fx:id="ageErrorLabel" text="L'âge doit être entre 18 et 100" style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" visible="false" managed="false"/>
                                            </children>
                                        </VBox>

                                        <!-- Phone -->
                                        <VBox spacing="5.0" GridPane.columnIndex="1">
                                            <children>
                                                <Label text="Téléphone *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                                <TextField fx:id="phoneField" promptText="Ex: +212 6XX XXX XXX" style="-fx-font-size: 13px; -fx-padding: 10px;" />
                                                <Label fx:id="phoneErrorLabel" text="Le téléphone est requis" style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" visible="false" managed="false"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </GridPane>

                                <!-- Email -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Email *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                        <TextField fx:id="emailField" promptText="Ex: ahmed@farm.ma" style="-fx-font-size: 13px; -fx-padding: 10px;" />
                                        <Label fx:id="emailErrorLabel" text="Email invalide" style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" visible="false" managed="false"/>
                                    </children>
                                </VBox>

                                <!-- Address -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Adresse" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                        <TextArea fx:id="addressTextArea" promptText="Ex: 123 Rue Farm, Rabat" prefRowCount="2" style="-fx-font-size: 13px;" wrapText="true" />
                                    </children>
                                </VBox>

                                <!-- Emergency Contact -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Contact d'Urgence" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                        <TextField fx:id="emergencyContactField" promptText="Ex: Fatima Hassan +212 6XX XXX XXX" style="-fx-font-size: 13px; -fx-padding: 10px;" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Employment Information Section -->
                        <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label text="Informations d'Emploi" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #343a40;" />

                                <!-- Job Title -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Titre du Poste *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                        <ComboBox fx:id="jobTitleComboBox" promptText="Sélectionnez un titre" prefWidth="540.0" style="-fx-font-size: 13px;" />
                                        <Label fx:id="jobTitleErrorLabel" text="Le titre du poste est requis" style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" visible="false" managed="false"/>
                                    </children>
                                </VBox>

                                <!-- Supervisor (Conditional - Only for Farmhands) -->
                                <VBox fx:id="supervisorSection" spacing="5.0" visible="false" managed="false">
                                    <children>
                                        <Label text="Superviseur *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                        <ComboBox fx:id="supervisorComboBox" promptText="Sélectionnez un superviseur" prefWidth="540.0" style="-fx-font-size: 13px;" />
                                        <Label fx:id="supervisorErrorLabel" text="Le superviseur est requis pour les ouvriers" style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" visible="false" managed="false" />
                                    </children>
                                </VBox>

                                <!-- Hire Date and Salary Row -->
                                <GridPane hgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                                    </columnConstraints>
                                    <children>
                                        <!-- Hire Date -->
                                        <VBox spacing="5.0" GridPane.columnIndex="0">
                                            <children>
                                                <Label text="Date d'Embauche" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                                <DatePicker fx:id="hireDatePicker" promptText="JJ/MM/AAAA" prefWidth="250.0" style="-fx-font-size: 13px;" />
                                            </children>
                                        </VBox>

                                        <!-- Salary -->
                                        <VBox spacing="5.0" GridPane.columnIndex="1">
                                            <children>
                                                <Label text="Salaire (MAD) *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                                <TextField fx:id="salaryField" promptText="Ex: 5000.00" style="-fx-font-size: 13px; -fx-padding: 10px;" />
                                                <Label fx:id="salaryErrorLabel" text="Le salaire doit être un nombre valide" style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" visible="false" managed="false"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </GridPane>

                                <!-- Shift -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Équipe *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                                        <ComboBox fx:id="shiftComboBox" promptText="Sélectionnez une équipe" prefWidth="540.0" style="-fx-font-size: 13px;" />
                                        <Label fx:id="shiftErrorLabel" text="L'équipe est requise" style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" visible="false" managed="false"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <!-- Bottom Buttons -->
        <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-width: 1px 0 0 0;"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" prefHeight="70.0">
            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>
            <children>
                <Button fx:id="saveButton" text="Enregistrer" onAction="#handleSave" prefWidth="130.0" prefHeight="40.0"
                        style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-cursor: hand;" />

                <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel" prefWidth="130.0" prefHeight="40.0"
                        style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5px; -fx-cursor: hand;" />
            </children>
        </HBox>
    </children>

</AnchorPane>