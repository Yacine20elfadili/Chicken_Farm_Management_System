<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.farm.controller.dialogs.SellEggsDialogController"
      prefWidth="750.0"
      prefHeight="480.0"
      spacing="15"
      style="-fx-background-color: #ffffff;">

    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0"/>
    </padding>

    <!-- Dialog Title -->
    <VBox spacing="3.0">
        <Label text="💰 Vendre des Œufs"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e2939;"/>
        <Label text="Sélectionnez les quantités à vendre par maison"
               style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
    </VBox>

    <Separator/>

    <!-- Error Label -->
    <Label fx:id="errorLabel"
           style="-fx-text-fill: #dc3545; -fx-padding: 10; -fx-background-color: #f8d7da; -fx-border-color: #f5c6cb; -fx-border-radius: 5; -fx-background-radius: 5;"
           text="Error message" visible="false" managed="false" wrapText="true"/>

    <!-- Main Content - Horizontal Layout -->
    <HBox spacing="20.0" VBox.vgrow="ALWAYS">

        <!-- Left Side - Houses List -->
        <VBox spacing="10.0" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8;">
            <Label text="🏠 Maisons Pondeuses"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <Label text="[Stock disponible] → Quantité à vendre"
                   style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox fx:id="housesListContainer" spacing="10.0" style="-fx-padding: 5 10 5 0;">
                    <!-- House rows will be added dynamically -->
                    <!-- Each row: HouseName [available eggs] → [input field 0] -->
                </VBox>
            </ScrollPane>
        </VBox>

        <!-- Right Side - Form and Confirm -->
        <VBox spacing="15.0" prefWidth="220.0"
              style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8;">

            <!-- Confirm Button (top) - disabled until qty > 0 -->
            <Button fx:id="confirmButton" text="✓ Confirmer Vente" onAction="#handleConfirm"
                    disable="true" maxWidth="Infinity"
                    style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 6; -fx-cursor: hand;"/>

            <!-- Total to sell display -->
            <HBox alignment="CENTER" spacing="8.0"
                  style="-fx-background-color: #e8f5e9; -fx-padding: 10; -fx-background-radius: 5;">
                <Label text="Total:" style="-fx-font-size: 12px; -fx-text-fill: #2e7d32;"/>
                <Label fx:id="totalToSellLabel" text="0"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1b5e20;"/>
                <Label text="œufs" style="-fx-font-size: 12px; -fx-text-fill: #2e7d32;"/>
            </HBox>

            <Separator/>

            <!-- Date de Vente -->
            <VBox spacing="8.0">
                <Label text="Date de Vente" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                <DatePicker fx:id="saleDatePicker" maxWidth="Infinity"/>
            </VBox>

            <!-- Prix par Œuf (Optional) -->
            <VBox spacing="8.0">
                <Label text="Prix par Œuf (MAD)" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                <TextField fx:id="priceField" promptText="Optionnel..."
                           style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 12;"/>
            </VBox>

            <!-- Nom du Client (Optional) -->
            <VBox spacing="8.0">
                <Label text="Nom du Client" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                <TextField fx:id="customerField" promptText="Optionnel..."
                           style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 12;"/>
            </VBox>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Cancel Button (bottom) -->
            <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel" maxWidth="Infinity"
                    style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
        </VBox>

    </HBox>

</VBox>
