<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.farm.controller.dialogs.AddEditFeedDialogController"
      prefHeight="550.0" prefWidth="600.0" spacing="15.0" styleClass="dialog-container">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Dialog Title -->
    <Label fx:id="dialogTitle" styleClass="dialog-title" text="Ajouter Aliment" />

    <!-- Form Content -->
    <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="form-scroll">
        <content>
            <VBox spacing="15.0">
                <padding>
                    <Insets bottom="10.0" right="10.0" />
                </padding>

                <!-- Name -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Nom de l'Aliment *" />
                    <TextField fx:id="nameField" promptText="Ex: Aliment Couche" styleClass="form-input" />
                    <Label fx:id="nameErrorLabel" styleClass="error-label" text="" />
                </VBox>

                <!-- Type -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Type *" />
                    <ComboBox fx:id="typeComboBox" prefWidth="200.0" promptText="Sélectionner le type" styleClass="form-input" />
                    <Label fx:id="typeErrorLabel" styleClass="error-label" text="" />
                </VBox>

                <!-- Quantity -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Quantité (kg) *" />
                    <TextField fx:id="quantityField" promptText="Ex: 500" styleClass="form-input" />
                    <Label fx:id="quantityErrorLabel" styleClass="error-label" text="" />
                </VBox>

                <!-- Price Per Kg -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Prix par kg ($) *" />
                    <TextField fx:id="pricePerKgField" promptText="Ex: 18.50" styleClass="form-input" />
                    <Label fx:id="priceErrorLabel" styleClass="error-label" text="" />
                </VBox>

                <!-- Supplier -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Fournisseur" />
                    <TextField fx:id="supplierField" promptText="Nom du fournisseur" styleClass="form-input" />
                </VBox>

                <!-- Expiry Date -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Date d'Expiration" />
                    <DatePicker fx:id="expiryDatePicker" styleClass="form-input" />
                </VBox>

                <!-- Min Stock Level -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Stock Minimum (kg)" />
                    <TextField fx:id="minStockField" promptText="Ex: 100" styleClass="form-input" />
                    <Label fx:id="minStockErrorLabel" styleClass="error-label" text="" />
                </VBox>
            </VBox>
        </content>
    </ScrollPane>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="Annuler" />
        <Button onAction="#handleSave" styleClass="btn-primary" text="Enregistrer" />
    </HBox>
</VBox>
