<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="600.0" spacing="15.0" styleClass="root" stylesheets="@../../css/dialogs.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.dialogs.AddEditMedicationDialogController">

    <!-- ================= HEADER ================= -->
    <VBox spacing="5">
        <Label fx:id="dialogTitle" styleClass="title" text="💊 Ajouter Médicament" />

        <Label styleClass="subtitle" text="Créer un médicament du stock" />
    </VBox>

    <Separator />

    <!-- ================= MAIN CONTENT ================= -->
    <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="transparent-scroll" VBox.vgrow="ALWAYS">

        <content>
            <VBox spacing="15.0">

                <!-- Name -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Nom du Médicament *" />
                    <TextField fx:id="nameField" promptText="Ex: Vitamine Complexe" />
                    <Label fx:id="nameErrorLabel" styleClass="error-label" />
                </VBox>

                <!-- Type -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Type *" />
                    <ComboBox fx:id="typeComboBox" promptText="Sélectionner le type" />
                    <Label fx:id="typeErrorLabel" styleClass="error-label" />
                </VBox>

                <!-- Quantity -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Quantité *" />
                    <TextField fx:id="quantityField" promptText="Ex: 100" />
                    <Label fx:id="quantityErrorLabel" styleClass="error-label" />
                </VBox>

                <!-- Unit -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Unité *" />
                    <ComboBox fx:id="unitComboBox" promptText="Sélectionner l'unité" />
                    <Label fx:id="unitErrorLabel" styleClass="error-label" />
                </VBox>

                <!-- Price -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Prix par Unité (DH) *" />
                    <TextField fx:id="pricePerUnitField" promptText="Ex: 5.50" />
                    <Label fx:id="priceErrorLabel" styleClass="error-label" />
                </VBox>

                <!-- Supplier -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Fournisseur" />
                    <TextField fx:id="supplierField" promptText="Nom du fournisseur" styleClass="error-label" />
                </VBox>

                <!-- Purchase Date -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Date d'Achat" />
                    <DatePicker fx:id="purchaseDatePicker" />
                </VBox>

                <!-- Expiry Date -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Date d'Expiration" />
                    <DatePicker fx:id="expiryDatePicker" />
                </VBox>

                <!-- Min Stock -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Stock Minimum" />
                    <TextField fx:id="minStockField" promptText="Ex: 20" />
                    <Label fx:id="minStockErrorLabel" styleClass="error-label" />
                </VBox>

                <!-- Usage -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Instructions d'Utilisation" />
                    <TextArea fx:id="usageTextArea" prefRowCount="3" promptText="Ex: 1 comprimé par 10 oiseaux par jour" styleClass="error-label" wrapText="true" />
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

    <Separator />

    <!-- ================= BUTTON BAR ================= -->
    <HBox alignment="CENTER_RIGHT" spacing="15">

        <Button onAction="#handleCancel" text="Annuler">
         <styleClass>
            <String fx:value="btn" />
            <String fx:value="btn-cancel" />
         </styleClass></Button>

        <Button onAction="#handleSave" text="Enregistrer">
         <styleClass>
            <String fx:value="btn" />
            <String fx:value="btn-save" />
         </styleClass></Button>
    </HBox>
   <padding>
      <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
   </padding>

</VBox>
