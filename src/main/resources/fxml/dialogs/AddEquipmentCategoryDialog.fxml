<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.farm.controller.dialogs.AddEquipmentCategoryDialogController"
      prefHeight="450.0" prefWidth="600.0" spacing="15.0" styleClass="dialog-container">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Dialog Title -->
    <Label fx:id="dialogTitle" styleClass="dialog-title" text="Ajouter Catégorie d'Équipement" />

    <!-- Form Content -->
    <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="form-scroll">
        <content>
            <VBox spacing="15.0">
                <padding>
                    <Insets bottom="10.0" right="10.0" />
                </padding>

                <!-- Name -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Nom de la Catégorie *" />
                    <TextField fx:id="nameField" promptText="Ex: Pelles, Mangeoires, Pompes" styleClass="form-input" />
                    <Label fx:id="nameErrorLabel" styleClass="error-label" text="" />
                </VBox>

                <!-- Category Type -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Type *" />
                    <ComboBox fx:id="categoryComboBox" prefWidth="200.0" promptText="Sélectionner le type" styleClass="form-input" />
                    <Label fx:id="categoryErrorLabel" styleClass="error-label" text="" />
                </VBox>

                <!-- Location -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Localisation *" />
                    <TextField fx:id="locationField" promptText="Ex: Hangar Principal, Maison 1" styleClass="form-input" />
                    <Label fx:id="locationErrorLabel" styleClass="error-label" text="" />
                </VBox>

                <!-- Notes -->
                <VBox spacing="5.0">
                    <Label styleClass="form-label" text="Notes" />
                    <TextArea fx:id="notesTextArea" prefRowCount="3" promptText="Informations supplémentaires..." styleClass="form-input" wrapText="true" />
                </VBox>

                <!-- Info Text -->
                <Label styleClass="info-text" text="Note: La quantité sera 0 par défaut. Ajoutez des équipements individuels après création." wrapText="true" />
            </VBox>
        </content>
    </ScrollPane>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="Annuler" />
        <Button onAction="#handleSave" styleClass="btn-primary" text="Enregistrer" />
    </HBox>
</VBox>