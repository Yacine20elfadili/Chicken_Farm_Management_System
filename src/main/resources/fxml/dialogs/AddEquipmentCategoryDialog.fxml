<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="600.0" spacing="15.0" styleClass="root" stylesheets="@../../css/dialogs.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.dialogs.AddEquipmentCategoryDialogController">

    <!-- ================= HEADER ================= -->
    <VBox spacing="5">

        <!-- Title -->
        <Label fx:id="dialogTitle" styleClass="title" text="🚜 Ajouter Catégorie d'Équipement" />

        <!-- Subtitle -->
        <Label styleClass="subtitle" text="Définissez une catégorie pour organiser vos équipements" />
    </VBox>

    <Separator />

    <!-- ================= MAIN CONTENT ================= -->
    <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="transparent-scroll" VBox.vgrow="ALWAYS">

        <content>
            <VBox spacing="15">

                <!-- Name -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Nom de la Catégorie *" />
                    <TextField fx:id="nameField" promptText="Ex: Pelles, Mangeoires, Pompes" />
                    <Label fx:id="nameErrorLabel" styleClass="error-label" />
                </VBox>

                <!-- Category Type -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Type *" />
                    <ComboBox fx:id="categoryComboBox" promptText="Sélectionner le type" />
                    <Label fx:id="categoryErrorLabel" styleClass="error-label" />
                </VBox>

                <!-- Location -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Localisation *" />
                    <TextField fx:id="locationField" promptText="Ex: Hangar Principal, Maison 1" />
                    <Label fx:id="locationErrorLabel" styleClass="error-label" />
                </VBox>

                <!-- Notes -->
                <VBox spacing="5">
                    <Label styleClass="section-title" text="Notes" />
                    <TextArea fx:id="notesTextArea" prefRowCount="3" promptText="Ex: Utilisé pour le nettoyage quotidien" wrapText="true" />
                </VBox>

                <!-- Info Text -->
                <Label styleClass="label-small-warning" text="Note : La quantité sera 0 par défaut. Ajoutez des équipements individuels après création." wrapText="true" />
            </VBox>
        </content>
    </ScrollPane>

    <Separator />

    <!-- ================= BUTTONS ================= -->
    <HBox alignment="CENTER_RIGHT" spacing="15">

        <Button onAction="#handleCancel" text="Annuler">
         <styleClass>
            <String fx:value="btn" />
            <String fx:value="btn-cancel" />
         </styleClass></Button>

        <Button onAction="#handleSave" prefHeight="45" text="Enregistrer">
         <styleClass>
            <String fx:value="btn" />
            <String fx:value="btn-save" />
         </styleClass></Button>
    </HBox>
   <padding>
      <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
   </padding>

</VBox>
