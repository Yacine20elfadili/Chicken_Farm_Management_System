<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.farm.controller.dialogs.RecordMortalityDialogController"
      prefWidth="550.0"
      prefHeight="720.0"
      spacing="12"
      style="-fx-background-color: #ffffff;">

    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0"/>
    </padding>

    <!-- Dialog Title -->
    <VBox spacing="5.0">
        <Label text="☠️ Record Mortality"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e2939;"/>
        <Label text="Record chicken deaths and update house counts."
               style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
    </VBox>

    <Separator/>

    <!-- Scrollable Form Content -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <VBox spacing="15.0" style="-fx-padding: 5 10 5 0;">

            <!-- Form Content -->
            <VBox spacing="15.0">
                <!-- House Selection -->
                <VBox spacing="8.0">
                    <Label text="Select House" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <ComboBox fx:id="houseComboBox" promptText="Select house..." maxWidth="Infinity"
                              style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </VBox>

                <!-- Death Date -->
                <VBox spacing="8.0">
                    <Label text="Death Date" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <DatePicker fx:id="deathDatePicker" maxWidth="Infinity"/>
                </VBox>

                <!-- Death Count -->
                <VBox spacing="8.0">
                    <Label text="Number of Deaths" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <TextField fx:id="deathCountField" promptText="e.g., 5"
                               style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 12;"/>
                </VBox>

                <!-- Cause of Death -->
                <VBox spacing="8.0">
                    <Label text="Cause of Death" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <ComboBox fx:id="causeComboBox" promptText="Select or type cause..."
                              editable="true" maxWidth="Infinity"
                              style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </VBox>
            </VBox>

            <Separator/>

            <!-- Additional Details Section -->
            <VBox spacing="12.0"
                  style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8;">
                <Label text="📋 Additional Details"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #666666;"/>

                <!-- Symptoms -->
                <VBox spacing="5.0">
                    <Label text="Symptoms (Optional)" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    <TextArea fx:id="symptomsArea" promptText="Describe symptoms observed..."
                              prefRowCount="2" wrapText="true"
                              style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </VBox>

                <!-- Outbreak Status -->
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <CheckBox fx:id="isOutbreakCheckBox" text="Mark as outbreak"
                              style="-fx-text-fill: #333333;"/>
                </HBox>

                <!-- Recorded By -->
                <VBox spacing="5.0">
                    <Label text="Recorded By" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    <TextField fx:id="recordedByField" promptText="Worker name..."
                               style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 12;"/>
                </VBox>

                <!-- Notes -->
                <VBox spacing="5.0">
                    <Label text="Notes (Optional)" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
                    <TextArea fx:id="notesArea" promptText="Additional notes..."
                              prefRowCount="2" wrapText="true"
                              style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </VBox>
            </VBox>

            <!-- Warning Label -->
            <HBox spacing="10.0" alignment="CENTER_LEFT"
                  style="-fx-background-color: #fff3cd; -fx-padding: 12; -fx-background-radius: 5;">
                <Label text="⚠" style="-fx-font-size: 18px; -fx-text-fill: #856404;"/>
                <Label text="Recording mortality will automatically decrease the chicken count in the selected house."
                       wrapText="true" style="-fx-text-fill: #856404; -fx-font-size: 12px;"
                       HBox.hgrow="ALWAYS"/>
            </HBox>

        </VBox>
    </ScrollPane>

    <!-- Error Label -->
    <Label fx:id="errorLabel" style="-fx-text-fill: #dc3545;" wrapText="true" visible="false" managed="false"/>

    <Separator/>

    <!-- Button Bar - Fixed at bottom -->
    <HBox spacing="12.0" alignment="CENTER_RIGHT"
          style="-fx-padding: 10 0 0 0;">
        <Button text="Cancel" onAction="#handleCancel"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"
                prefWidth="100"/>
        <Button text="Record Deaths" onAction="#handleSave"
                style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"
                prefWidth="150"/>
    </HBox>
</VBox>
