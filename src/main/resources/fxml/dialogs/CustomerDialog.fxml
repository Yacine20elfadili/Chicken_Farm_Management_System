<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="650.0" spacing="15.0" styleClass="root" stylesheets="@../../css/dialogs.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.dialogs.CustomerDialogController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <!-- Dialog Title -->
        <VBox spacing="5.0">
            <Label fx:id="dialogTitle" styleClass="title" text="👤 Nouveau Client" />
            <Label styleClass="subtitle" text="Ajouter un nouveau client (Entreprise ou Particulier)." />
        </VBox>

        <Separator />

        <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="transparent-scroll" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="15.0">
                    <padding>
                        <Insets bottom="10.0" right="10.0" />
                    </padding>
                    <children>
                        <!-- Type Selection -->
                        <VBox spacing="5.0" styleClass="form-section">
                            <Label styleClass="section-title" text="Type de Client *" />
                            <HBox spacing="20.0">
                                <fx:define>
                                    <ToggleGroup fx:id="typeGroup" />
                                </fx:define>
                                <RadioButton fx:id="companyRadio" text="Entreprise" toggleGroup="$typeGroup" selected="true" />
                                <RadioButton fx:id="individualRadio" text="Particulier" toggleGroup="$typeGroup" />
                            </HBox>
                        </VBox>

                        <Separator />

                        <!-- Company Info (Visible only for Company) -->
                        <VBox fx:id="companySection" spacing="10.0" styleClass="form-section">
                            <Label styleClass="section-title" text="📋 Informations Entreprise" />
                            <HBox spacing="15.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Nom de la Société *" />
                                    <TextField fx:id="companyNameField" promptText="Ex: SARL Atlas Foods" styleClass="form-input" />
                                </VBox>
                                <VBox spacing="5.0" prefWidth="200.0">
                                    <Label text="Forme Juridique" />
                                    <ComboBox fx:id="legalFormCombo" prefWidth="200.0" promptText="Sélectionner" styleClass="form-input" />
                                </VBox>
                            </HBox>
                            <HBox spacing="15.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="ICE (15 chiffres) *" />
                                    <TextField fx:id="iceField" promptText="Ex: 001234567891234" styleClass="form-input" />
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="RC (Registre de Commerce)" />
                                    <TextField fx:id="rcField" promptText="Ex: 12345" styleClass="form-input" />
                                </VBox>
                            </HBox>
                            <VBox spacing="5.0">
                                <Label text="Site Web" />
                                <TextField fx:id="websiteField" promptText="Ex: www.atlasfoods.ma" styleClass="form-input" />
                            </VBox>
                        </VBox>

                        <Separator />

                        <!-- Contact Info (Always visible) -->
                        <VBox spacing="10.0" styleClass="form-section">
                            <Label styleClass="section-title" text="📞 Contact Principal" />
                            <HBox spacing="15.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Nom du Contact *" />
                                    <TextField fx:id="nameField" promptText="Ex: Mohammed Alami" styleClass="form-input" />
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Téléphone *" />
                                    <TextField fx:id="phoneField" promptText="Ex: 0612345678" styleClass="form-input" />
                                </VBox>
                            </HBox>
                            <HBox spacing="15.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Email" />
                                    <TextField fx:id="emailField" promptText="Ex: contact@atlasfoods.ma" styleClass="form-input" />
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Adresse" />
                                    <TextField fx:id="addressField" promptText="Ex: Rue 12, Zone Ind., Casablanca" styleClass="form-input" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <Separator />

                        <!-- Secondary Contact (Collapsible) -->
                        <VBox spacing="10.0" styleClass="form-section">
                            <Label styleClass="section-title" text="📞 Contact Secondaire (Optionnel)" />
                            <HBox spacing="15.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Nom" />
                                    <TextField fx:id="secondaryNameField" promptText="Ex: Fatima Idrissi" styleClass="form-input" />
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Téléphone" />
                                    <TextField fx:id="secondaryPhoneField" promptText="Ex: 0698765432" styleClass="form-input" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <Separator />

                        <!-- Commercial Terms (Visible for Company) -->
                        <VBox fx:id="termsSection" spacing="10.0" styleClass="form-section">
                            <Label styleClass="section-title" text="💼 Conditions Commerciales" />
                            <HBox spacing="15.0">
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Conditions de Paiement *" />
                                    <ComboBox fx:id="paymentTermsCombo" prefWidth="200.0" styleClass="form-input" />
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <Label text="Calendrier de Livraison" />
                                    <TextField fx:id="deliveryScheduleField" promptText="Ex: Chaque Mardi, Jeudi" styleClass="form-input" />
                                </VBox>
                            </HBox>
                            <VBox spacing="5.0">
                                <Label text="Achats Habituels" />
                                <TextField fx:id="usualPurchasesField" promptText="Ex: Œufs, Poulets" styleClass="form-input" />
                            </VBox>
                        </VBox>

                        <Separator />

                        <!-- Notes -->
                        <VBox spacing="5.0" styleClass="form-section">
                            <Label styleClass="section-title" text="📝 Notes Internes" />
                            <TextArea fx:id="notesArea" prefRowCount="3" promptText="Notes sur ce client..." styleClass="form-input" wrapText="true" />
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <Separator />

        <!-- Buttons -->
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button onAction="#handleCancel" text="Annuler">
                    <styleClass>
                        <String fx:value="btn" />
                        <String fx:value="btn-cancel" />
                    </styleClass>
                </Button>
                <Button onAction="#handleSave" text="Enregistrer">
                    <styleClass>
                        <String fx:value="btn" />
                        <String fx:value="btn-save" />
                    </styleClass>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>
