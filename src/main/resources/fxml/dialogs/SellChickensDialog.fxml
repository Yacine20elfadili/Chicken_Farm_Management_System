<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.farm.controller.dialogs.SellChickensDialogController"
      prefWidth="500.0"
      prefHeight="550.0"
      spacing="15"
      style="-fx-background-color: #ffffff;">

    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0"/>
    </padding>

    <!-- Dialog Title -->
    <VBox spacing="5.0">
        <Label text="💰 Sell Chickens"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e2939;"/>
        <Label fx:id="sourceHouseLabel" text="Selling from: FemaleMeat-House-1"
               style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
    </VBox>

    <Separator/>

    <!-- Available Chickens Info -->
    <HBox alignment="CENTER_LEFT" spacing="12.0"
          style="-fx-background-color: #fff8e1; -fx-padding: 12; -fx-background-radius: 5;">
        <Label text="Available chickens:" style="-fx-font-weight: bold; -fx-text-fill: #f57c00;"/>
        <Label fx:id="availableChickensLabel" text="0"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e65100;"/>
    </HBox>

    <Separator/>

    <!-- Form Content -->
    <VBox spacing="15.0">
        <!-- Quantity to Sell -->
        <VBox spacing="8.0">
            <Label text="Quantity to Sell" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <HBox spacing="12.0" alignment="CENTER_LEFT">
                <TextField fx:id="quantityField" promptText="Enter quantity..." prefWidth="200"
                           style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 12;"/>
                <Button text="Sell All" onAction="#handleSellAll"
                        style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8 16; -fx-background-radius: 5; -fx-cursor: hand;"
                        prefWidth="90"/>
            </HBox>
            <Label fx:id="quantityErrorLabel" text="" style="-fx-text-fill: #dc3545; -fx-font-size: 11px;" visible="false"/>
        </VBox>

        <!-- Date of Sale -->
        <VBox spacing="8.0">
            <Label text="Date of Sale" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <DatePicker fx:id="saleDatePicker" prefWidth="220"/>
        </VBox>
    </VBox>

    <Separator/>

    <!-- Optional Fields Section -->
    <VBox spacing="12.0"
          style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8;">
        <Label text="📋 Optional Fields (for record keeping)"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #666666;"/>

        <!-- Price per Piece -->
        <VBox spacing="5.0">
            <Label text="Price per Piece" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
                <TextField fx:id="priceField" promptText="(Optional) Price..." prefWidth="180"
                           style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 12;"/>
                <Label text="MAD" style="-fx-text-fill: #888888; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>

        <!-- Customer Name -->
        <VBox spacing="5.0">
            <Label text="Customer Name" style="-fx-text-fill: #555555; -fx-font-size: 12px;"/>
            <TextField fx:id="customerField" promptText="(Optional) Customer name..."
                       style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 12;"/>
        </VBox>
    </VBox>

    <!-- Error Label -->
    <Label fx:id="errorLabel" style="-fx-text-fill: #dc3545;" wrapText="true" visible="false" managed="false"/>

    <Separator/>

    <!-- Button Bar -->
    <HBox spacing="12.0" alignment="CENTER_RIGHT">
        <padding>
            <Insets top="10.0"/>
        </padding>
        <Button text="Cancel" onAction="#handleCancel"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"
                prefWidth="100"/>
        <Button fx:id="confirmButton" text="Confirm Sale" onAction="#handleConfirm"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"
                prefWidth="140"/>
    </HBox>
</VBox>
