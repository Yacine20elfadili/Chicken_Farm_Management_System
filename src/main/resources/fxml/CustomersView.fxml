<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.CustomersController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <!-- Title and Actions -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="👥 Gestion des Clients" />
                        <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                            <ComboBox fx:id="filterCombo" prefWidth="150.0" promptText="Filtrer par type" style="-fx-background-radius: 5; -fx-border-radius: 5;" />
                            <Button fx:id="exportBtn" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;" text="📄 Exporter PDF" />
                            <Button fx:id="addCustomerBtn" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="+ Nouveau Client" />
                        </HBox>
                    </children>
                </HBox>

                <!-- Customers Table -->
                <TableView fx:id="customersTable" VBox.vgrow="ALWAYS" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colName" prefWidth="150.0" text="Nom / Entreprise" />
                        <TableColumn fx:id="colType" prefWidth="100.0" text="Type" />
                        <TableColumn fx:id="colContact" prefWidth="120.0" text="Contact" />
                        <TableColumn fx:id="colPhone" prefWidth="100.0" text="Téléphone" />
                        <TableColumn fx:id="colIce" prefWidth="120.0" text="ICE" />
                        <TableColumn fx:id="colBalance" prefWidth="100.0" text="Solde Impayé" />
                        <TableColumn fx:id="colVisits" prefWidth="70.0" text="Visites" />
                        <TableColumn fx:id="colStatus" prefWidth="80.0" text="Statut" />
                        <TableColumn fx:id="colActions" prefWidth="180.0" text="Actions" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
