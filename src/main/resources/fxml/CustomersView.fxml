<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" styleClass="main-content" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.farm.controller.CustomersController">
    <children>
        <!-- Header Section with consistent style -->
        <VBox styleClass="header" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="15.0" left="30.0" right="30.0" top="15.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Label styleClass="header-title" text="Gestion des Clients" textAlignment="LEFT" />
                                <Label styleClass="header-subtitle" text="Gérez vos clients et partenaires commerciaux" textAlignment="LEFT" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </padding>
                            <children>
                                <ComboBox fx:id="filterCombo" prefWidth="193.0" promptText="Filtrer par type" stylesheets="@../css/dialogs.css" />
                                <Button fx:id="addCustomerBtn" mnemonicParsing="false" styleClass="btn, btn-save" text="+ Nouveau Client" />
                                <Button fx:id="exportBtn" mnemonicParsing="false" styleClass="btn, btn-cancel" text="📄 Exporter PDF" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Main Content Area -->
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="60.0">
            <children>
                <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="main-content" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0" styleClass="main-content">
                            <padding>
                                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
                            </padding>

                            <children>
                                <!-- Customers Table Card -->
                                <VBox styleClass="metric-card" VBox.vgrow="ALWAYS">
                                    <children>
                                        <!-- Customers Table -->
                                        <TableView fx:id="customersTable" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                                <TableColumn fx:id="colName" prefWidth="150.0" text="Nom / Entreprise" />
                                                <TableColumn fx:id="colType" prefWidth="100.0" text="Type" />
                                                <TableColumn fx:id="colContact" prefWidth="120.0" text="Contact" />
                                                <TableColumn fx:id="colPhone" prefWidth="110.0" text="Téléphone" />
                                                <TableColumn fx:id="colIce" prefWidth="100.0" text="ICE" />
                                                <TableColumn fx:id="colBalance" prefWidth="120.0" text="Solde Impayé" />
                                                <TableColumn fx:id="colVisits" prefWidth="80.0" text="Visites" />
                                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Statut" />
                                                <TableColumn fx:id="colActions" prefWidth="130.0" text="Actions" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>