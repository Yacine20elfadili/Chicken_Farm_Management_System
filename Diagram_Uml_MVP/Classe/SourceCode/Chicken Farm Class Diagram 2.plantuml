class Task <<Entity>> {
    - id: int
    - description: String
    - status: String
    - dueDate: LocalDate
    - completedAt: LocalDateTime
    - assignedTo: String
    - houseId: int
    - category: String
    - crackedEggs: int
    - notes: String
