    + toString(): String
}

class Personnel <<Entity>> {
    - id: int
    - fullName: String
    - age: int
    - phone: String
    - email: String
    - jobTitle: String
    - hireDate: LocalDate
    - salary: double
    - shift: String
    - isActive: boolean
    - address: String
    - emergencyContact: String
    __
    + Personnel()
    + Personnel(fullName: String, age: int, phone: String, 
                email: String, jobTitle: String)
    + Personnel(id: int, fullName: String, age: int, phone: String,
                email: String, jobTitle: String, hireDate: LocalDate,
                salary: double, shift: String, isActive: boolean,
                address: String, emergencyContact: String)
    __
    + getId(): int
    + setId(id: int): void
    + getFullName(): String
    + setFullName(fullName: String): void
    + getAge(): int
    + setAge(age: int): void
    + getPhone(): String
    + setPhone(phone: String): void
    + getEmail(): String
    + setEmail(email: String): void
    + getJobTitle(): String
    + setJobTitle(jobTitle: String): void
    + getHireDate(): LocalDate
    + setHireDate(hireDate: LocalDate): void
    + getSalary(): double
    + setSalary(salary: double): void
    + getShift(): String
    + setShift(shift: String): void
    + isActive(): boolean
    + setActive(active: boolean): void
    + getAddress(): String
    + setAddress(address: String): void
    + getEmergencyContact(): String
    + setEmergencyContact(emergencyContact: String): void
    __
    + getYearsOfService(): int
    + isTracker(): boolean
    + isWorker(): boolean
    + equals(o: Object): boolean
    + hashCode(): int
    + toString(): String
}

