    + Task()
    + Task(description: String, dueDate: LocalDate, 
           assignedTo: String, category: String)
    + Task(id: int, description: String, status: String, dueDate: LocalDate,
           completedAt: LocalDateTime, assignedTo: String, houseId: int,
           category: String, crackedEggs: int, notes: String, priority: String)
    __
    + getId(): int
    + setId(id: int): void
    + getDescription(): String
    + setDescription(description: String): void
    + getStatus(): String
    + setStatus(status: String): void
    + getDueDate(): LocalDate
    + setDueDate(dueDate: LocalDate): void
    + getCompletedAt(): LocalDateTime
    + setCompletedAt(completedAt: LocalDateTime): void
    + getAssignedTo(): String
    + setAssignedTo(assignedTo: String): void
    + getHouseId(): int
    + setHouseId(houseId: int): void
    + getCategory(): String
    + setCategory(category: String): void
    + getCrackedEggs(): int
    + setCrackedEggs(crackedEggs: int): void
    + getNotes(): String
    + setNotes(notes: String): void
