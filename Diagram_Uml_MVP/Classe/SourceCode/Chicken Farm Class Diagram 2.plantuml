@startuml Class_Diagram_2_Storage_Personnel

title Class Diagram 2: Domain Model - Storage & Personnel

skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor<<Entity>> LightCyan
    BorderColor<<Entity>> Blue
}

class Feed <<Entity>> {
    - id: int
    - name: String
    - type: String
    - quantityKg: double
    - pricePerKg: double
    - supplier: String
    - lastRestockDate: LocalDate
    - expiryDate: LocalDate
    - minStockLevel: double
    __
    + Feed()
    + Feed(name: String, type: String, quantityKg: double, pricePerKg: double)
    + Feed(id: int, name: String, type: String, quantityKg: double,
           pricePerKg: double, supplier: String, lastRestockDate: LocalDate,
           expiryDate: LocalDate, minStockLevel: double)
    __
    + getId(): int
    + setId(id: int): void
    + getName(): String
    + setName(name: String): void
    + getType(): String
    + setType(type: String): void
    + getQuantityKg(): double
    + setQuantityKg(quantityKg: double): void
    + getPricePerKg(): double
    + setPricePerKg(pricePerKg: double): void
    + getSupplier(): String
    + setSupplier(supplier: String): void
    + getLastRestockDate(): LocalDate
    + setLastRestockDate(lastRestockDate: LocalDate): void
    + getExpiryDate(): LocalDate
    + setExpiryDate(expiryDate: LocalDate): void
    + getMinStockLevel(): double
    + setMinStockLevel(minStockLevel: double): void
    __
    + isLowStock(): boolean
    + isExpiredOrNearExpiry(): boolean
    + getTotalValue(): double
    + equals(o: Object): boolean
    + hashCode(): int
    + toString(): String
}

