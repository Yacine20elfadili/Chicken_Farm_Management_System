' ============================================
' FINANCIAL RELATIONSHIPS
' ============================================
UC_FIN ..> UC_FIN1 : <<include>>
UC_FIN <.. UC_FIN2 : <<extend>>
UC_FIN <.. UC_FIN3 : <<extend>>
UC_FIN <.. UC_FIN4 : <<extend>>
UC_FIN <.. UC_FIN5 : <<extend>>
UC_FIN1 ..> UC_FIN6 : <<include>>
UC_FIN1 ..> UC_FIN7 : <<include>>

' ============================================
' DOCUMENTS RELATIONSHIPS
' ============================================
UC_DOC ..> UC_DOC1 : <<include>>
UC_DOC <.. UC_DOC2 : <<extend>>
UC_DOC <.. UC_DOC3 : <<extend>>
UC_DOC <.. UC_DOC4 : <<extend>>
UC_DOC <.. UC_DOC5 : <<extend>>
UC_DOC1 ..> UC_DOC6 : <<include>>
UC_DOC6 ..> UC_DOC7 : <<include>>
UC_DOC6 ..> UC_DOC8 : <<include>>
UC_DOC2 ..> UC_CRM1 : <<uses>>
UC_DOC3 ..> UC_SCM1 : <<uses>>

' ============================================
' REPORTS RELATIONSHIPS
' ============================================
UC_REP ..> UC_REP1 : <<include>>
UC_REP <.. UC_REP2 : <<extend>>
UC_REP <.. UC_REP3 : <<extend>>
UC_REP <.. UC_REP4 : <<extend>>
UC_REP1 ..> UC_REP5 : <<include>>
UC_REP1 ..> UC_REP6 : <<include>>

' ============================================
