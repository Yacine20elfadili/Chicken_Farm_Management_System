@startuml Sequence_Diagram_7_Add_Personnel

title Sequence Diagram 7: Add Personnel with ID Card Generation - Alpha v2.0

actor "Cashier" as Cashier
participant "PersonnelView" as UI
participant "PersonnelController" as Controller
participant "ValidationUtil" as Validator
participant "PersonnelDAO" as DAO
participant "IdentityCardGenerator" as IDGen
participant "DateUtil" as DateUtil
participant "DatabaseConnection" as DB

== Add New Personnel ==

Cashier -> UI: Navigate to Personnel module
Cashier -> UI: Click "Add Personnel" button

UI -> Controller: handleAddPersonnel()
activate Controller

Controller -> UI: Show "Add Personnel" dialog
UI -> Cashier: Display personnel input form

Cashier -> UI: Enter personnel details:\n• Full Name: Fatima Zahra\n• Age: 28\n• Phone: 0612345678\n• Email: fatima@farm.ma\n• Type: Tracker\n• Shift: Morning\n• Salary: 4,500 MAD\n• Address: Casablanca
Cashier -> UI: Upload photo (optional)

Cashier -> UI: Click "Save" button

UI -> Controller: submitAddPersonnel(personnelData)

' Validate inputs
Controller -> Validator: isEmpty(fullName)
activate Validator
Validator --> Controller: false (valid)
deactivate Validator

Controller -> Validator: isValidEmail(email)
activate Validator
Validator --> Controller: true (valid)
deactivate Validator

Controller -> Validator: isValidPhone(phone)
activate Validator
note right: Moroccan format:\n06/07 + 8 digits
Validator --> Controller: true (valid)
deactivate Validator

' Validate age
Controller -> Controller: validateAge(28)
note right
    <b>Age Validation:</b>
    Min age: 18
    Max age: 65
    28 is valid ✓
end note

' Check email uniqueness
Controller -> DAO: getPersonnelByEmail(email)
activate DAO
DAO -> DB: executeQuery(\n"SELECT * FROM personnel\nWHERE email = ?")
activate DB
DB --> DAO: null (not found)
deactivate DB
DAO --> Controller: null (unique)
deactivate DAO

alt Validation Failed
    Controller -> UI: Show validation error
    UI -> Cashier: Display error
    
else Valid Input
    ' Get hire date
    Controller -> DateUtil: getCurrentDate()
    activate DateUtil
    DateUtil --> Controller: 2025-12-25
    deactivate DateUtil
    
    ' Create Personnel object
    Controller -> Controller: createPersonnelObject()
    note right
        <b>Personnel Object:</b>
        fullName = "Fatima Zahra"
        age = 28
        phone = "0612345678"
        email = "fatima@farm.ma"
        type = TRACKER
        hireDate = 2025-12-25
        salary = 4500.0
        shift = "Morning"
        isActive = true
        address = "Casablanca"
        photoBase64 = [uploaded image]
    end note
    
    ' Save to database
    Controller -> DAO: addPersonnel(personnel)
    activate DAO
    DAO -> DB: getConnection()
    activate DB
    DB --> DAO: Connection
    deactivate DB
    
    DAO -> DB: executeUpdate(\n"INSERT INTO personnel\n(fullName, age, phone, email,\ntype, hireDate, salary, shift,\nisActive, address, photoBase64)\nVALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)")
    activate DB
    DB --> DAO: success, generated ID = 15
    deactivate DB
    DAO --> Controller: true
    deactivate DAO
    
    ' Refresh personnel list
    Controller -> Controller: loadPersonnelData()
    Controller -> UI: Update personnel cards/table
    UI -> UI: Add new card:\n[📷 Fatima Zahra | Tracker | Morning]
    
    Controller -> UI: Show success message
    UI -> Cashier: Display:\n"✅ Personnel added!\n• Name: Fatima Zahra\n• Type: Tracker\n• ID: 15"
    
    ' Offer ID Card generation (Alpha enhancement)
    UI -> Cashier: Prompt: "Generate ID Card?"
    
    alt User Clicks "Yes"
        Cashier -> UI: Click "Generate ID Card"
        
        UI -> Controller: handleGenerateIdCard(personnelId)
        
        Controller -> DAO: getPersonnelById(15)
        activate DAO
        DAO --> Controller: personnel object
        deactivate DAO
        
        Controller -> IDGen: generateIdCard(personnel)
        activate IDGen
        
        ' Generate QR Code
        IDGen -> IDGen: generateQRCode(personnelData)
        note right
            <b>QR Code Data (JSON):</b>
            {
              "id": 15,
              "name": "Fatima Zahra",
              "type": "Tracker",
              "phone": "0612345678",
              "farmId": "CHKFARM-2025"
            }
            
            Uses ZXing library
        end note
        
        ' Build ID Card Image
        IDGen -> IDGen: buildIdCardImage()
        note right
            ┌──────────────────────────┐
            │  🐔 CHICKEN FARM         │
            │  ─────────────────────── │
            │  ┌────┐                  │
            │  │📷  │  Fatima Zahra    │
            │  │    │  Tracker         │
            │  └────┘                  │
            │  ID: EMP-2025-0015       │
            │  Phone: 0612345678       │
            │  ─────────────────────── │
            │  Hire: 25/12/2025        │
            │  [QR CODE]               │
            └──────────────────────────┘
        end note
        
        IDGen --> Controller: BufferedImage
        deactivate IDGen
        
        Controller -> UI: Show ID Card preview
        UI -> Cashier: Display ID card image
        
        Cashier -> UI: Click "Save to File"
        Controller -> IDGen: saveIdCardToFile(image, path)
        activate IDGen
        IDGen --> Controller: Saved to exports/ID_Fatima_Zahra.png
        deactivate IDGen
        
        Controller -> UI: Show success
        UI -> Cashier: "ID Card saved!"
    end
end

deactivate Controller



@enduml
