@startuml Class_Diagram_4_Controllers

title Class Diagram 4: Controller Layer - All Controllers - Alpha v2.0

skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor<<Controller>> LightSalmon
    BorderColor<<Controller>> Red
    BackgroundColor<<App>> Gold
    BorderColor<<App>> DarkOrange
    BackgroundColor<<Utility>> LightGreen
    BorderColor<<Utility>> DarkGreen
}

' ============================================
' APPLICATION ENTRY POINT
' ============================================

class App <<App>> {
    - {static} primaryStage: Stage
    __
    + start(stage: Stage): void
    + {static} main(args: String[]): void
    + {static} getPrimaryStage(): Stage
}

' ============================================
' AUTHENTICATION CONTROLLERS
' ============================================

class LoginController <<Controller>> {
    - userDAO: UserDAO
    - emailField: TextField
    - passwordField: PasswordField
    - errorLabel: Label
    __
    + initialize(): void
    + handleLogin(event: ActionEvent): void
    + handleSignUp(event: ActionEvent): void
    - validateCredentials(): boolean
    - showError(message: String): void
}

class SignUpController <<Controller>> {
    - userDAO: UserDAO
    - fullNameField: TextField
    - emailField: TextField
    - passwordField: PasswordField
    - confirmPasswordField: PasswordField
    __
    + initialize(): void
    + handleSignUp(event: ActionEvent): void
    + handleBackToLogin(event: ActionEvent): void
    - validateInputs(): boolean
}

' ============================================
' NAVIGATION CONTROLLERS
' ============================================

class MainWindowController <<Controller>> {
    - contentArea: StackPane
    - currentView: String
    __
    + initialize(): void
    + loadView(viewName: String): void
    + handleLogout(): void
    + setCurrentUser(user: User): void
}

class SidebarController <<Controller>> {
    - mainWindowController: MainWindowController
    __
    + initialize(): void
    + setMainWindowController(controller: MainWindowController): void
    + handleDashboardClick(): void
    + handleChickenBayClick(): void
    + handleEggsBayClick(): void
    + handleStorageClick(): void
    + handleTasksClick(): void
    + handlePersonnelClick(): void
    + handleCustomersClick(): void
    + handleSuppliersClick(): void
    + handleFinancialClick(): void
    + handleReportsClick(): void
    + handleDocumentsClick(): void
    + handleSettingsClick(): void
}

' ============================================
' CORE FEATURE CONTROLLERS
' ============================================

class DashboardController <<Controller>> {
    - chickenDAO: ChickenDAO
    - eggProductionDAO: EggProductionDAO
    - mortalityDAO: MortalityDAO
    - totalChickensLabel: Label
    - todayEggsLabel: Label
    - alertsLabel: Label
    - productionChart: BarChart
    __
    + initialize(): void
    + loadDashboardData(): void
    + refreshDashboard(): void
    - loadChickenStats(): void
    - loadEggStats(): void
    - loadAlerts(): void
    - load7DayChart(): void
}

class ChickenBayController <<Controller>> {
    - houseDAO: HouseDAO
    - chickenDAO: ChickenDAO
    - mortalityDAO: MortalityDAO
    - houseCardsContainer: FlowPane
    __
    + initialize(): void
    + loadHouseCards(): void
    + loadMortalityStats(): void
    + handleAddChickens(): void
    + handleRecordMortality(): void
    + handleTransferChickens(): void
    + handleSellChickens(): void
    + handleOptimization(): void
    + handleConfigureHouses(): void
    + refreshView(): void
}

class EggsBayController <<Controller>> {
    - eggProductionDAO: EggProductionDAO
    - houseDAO: HouseDAO
    - productionCardsContainer: FlowPane
    - totalStorageLabel: Label
    __
    + initialize(): void
    + loadProductionCards(): void
    + loadTotalStorage(): void
    + handleRecordCollection(): void
    + handleRemoveEggs(): void
    + refreshView(): void
}

class StorageController <<Controller>> {
    - feedDAO: FeedDAO
    - medicationDAO: MedicationDAO
    - equipmentCategoryDAO: EquipmentCategoryDAO
    - equipmentItemDAO: EquipmentItemDAO
    - feedTable: TableView
    - medicationTable: TableView
    - equipmentTable: TableView
    __
    + initialize(): void
    + loadFeedData(): void
    + loadMedicationData(): void
    + loadEquipmentData(): void
    + handleAddFeed(): void
    + handleAddMedication(): void
    + handleAddEquipment(): void
    + handleEditItem(): void
    + handleDeleteItem(): void
    + refreshView(): void
}

class TasksController <<Controller>> {
    - taskDAO: TaskDAO
    - personnelDAO: PersonnelDAO
    - tasksTable: TableView
    - filterComboBox: ComboBox
    __
    + initialize(): void
    + loadTasks(): void
    + handleCreateTask(): void
    + handleEditTask(): void
    + handleDeleteTask(): void
    + handleMarkAsDone(): void
    + handleFilterByStatus(): void
    + handleFilterByAssignee(): void
    + refreshView(): void
}

class PersonnelController <<Controller>> {
    - personnelDAO: PersonnelDAO
    - personnelTable: TableView
    - personnelCardsContainer: FlowPane
    __
    + initialize(): void
    + loadPersonnelData(): void
    + handleAddPersonnel(): void
    + handleEditPersonnel(): void
    + handleDeletePersonnel(): void
    + handleGenerateIdCard(): void
    + handleViewDetails(): void
    + refreshView(): void
}

