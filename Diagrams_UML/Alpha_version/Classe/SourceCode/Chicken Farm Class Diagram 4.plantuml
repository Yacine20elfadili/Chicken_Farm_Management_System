    + handleAddSupplier(): void
    + handleEditSupplier(): void
    + handleDeleteSupplier(): void
    + handleFilterByCategory(): void
    + refreshView(): void
}

class FinancialTrackingController <<Controller>> {
    - financialDAO: FinancialDAO
    - transactionsTable: TableView
    - balanceLabel: Label
    - incomeLabel: Label
    - expenseLabel: Label
    __
    + initialize(): void
    + loadTransactions(): void
    + handleAddIncome(): void
    + handleAddExpense(): void
    + handleEditTransaction(): void
    + handleDeleteTransaction(): void
    + calculateBalance(): double
    + filterByType(type: String): void
    + filterByDateRange(start: LocalDate, end: LocalDate): void
    + refreshView(): void
}

class FarmDocumentController <<Controller>> {
    - documentDAO: DocumentDAO
    - customerDAO: CustomerDAO
    - supplierDAO: SupplierDAO
    - documentsTable: TableView
    __
    + initialize(): void
    + loadDocuments(): void
    + handleGenerateInvoice(): void
    + handleGenerateBonCommande(): void
    + handleGenerateBonLivraison(): void
    + handleGenerateDevis(): void
    + handlePreviewDocument(): void
    + handleExportPDF(): void
    + handlePrintDocument(): void
    + handleDeleteDocument(): void
    + refreshView(): void
}

class ReportsController <<Controller>> {
    - reportDAO: ReportDAO
    - reportsTable: TableView
    - reportTypeComboBox: ComboBox
    __
    + initialize(): void
