    + handleGenerateFinancialReport(): void
    + handleGenerateProductionReport(): void
    + handleGenerateInventoryReport(): void
    + handleGenerateConsumptionReport(): void
    + handleExportToPDF(): void
    + handleViewReport(): void
    + refreshView(): void
