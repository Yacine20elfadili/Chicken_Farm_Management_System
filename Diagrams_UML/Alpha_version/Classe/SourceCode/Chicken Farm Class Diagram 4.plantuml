' ALPHA v2.0 NEW CONTROLLERS
' ============================================

class CustomersController <<Controller>> {
    - customerDAO: CustomerDAO
    - customersTable: TableView
    - searchField: TextField
    __
    + initialize(): void
    + loadCustomers(): void
    + handleAddCustomer(): void
    + handleEditCustomer(): void
    + handleDeleteCustomer(): void
    + handleSearchCustomer(): void
    + handleViewDetails(): void
    + refreshView(): void
}

class SuppliersController <<Controller>> {
